# Contact-form email delivery — used by app/api/enquiry/route.ts
#
# 1. Create a free account + API key at https://resend.com
# 2. Verify your sending domain (bikabanquets.com) in Resend so mail isn't
#    marked as spam. Until then, ENQUIRY_FROM_EMAIL can stay onboarding@resend.dev.
# 3. Copy this file to .env.local and fill in the key (.env.local is gitignored),
#    and set the same vars in your host's dashboard (e.g. Vercel → Settings → Env).
#
# If RESEND_API_KEY is missing, the form still works via the WhatsApp button;
# only the email path is disabled.

RESEND_API_KEY=
ENQUIRY_TO_EMAIL=contact@bikabanquets.com
ENQUIRY_FROM_EMAIL="Bika Banquets <onboarding@resend.dev>"
