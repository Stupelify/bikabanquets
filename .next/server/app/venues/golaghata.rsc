1e:T77b,{"@context":"https://schema.org","@type":"EventVenue","name":"Bika Banquets — Golaghata","description":"Bika Banquets Golaghata is our original and flagship venue, operating since 2016 in the heart of Dakshindari. The main hall comfortably seats up to 400 guests and handles 600 in a floating arrangement, making it one of the largest banquet spaces in North Kolkata. The fully centralised air-conditioning system, coupled with 100% power backup, ensures a comfortable environment regardless of the season. A dedicated mandap stage, full PA system, projection screen, and LED lighting rig make it equally suited to traditional Bengali wedding ceremonies, reception galas, and corporate functions.","url":"https://bikabanquets.com/venues/golaghata","telephone":"+918961333313","address":{"@type":"PostalAddress","streetAddress":"76/1 Golaghata Road, Dakshindari","addressLocality":"Kolkata","addressRegion":"West Bengal","postalCode":"700048","addressCountry":"IN"},"geo":{"@type":"GeoCoordinates","latitude":22.5965,"longitude":88.4037},"maximumAttendeeCapacity":600,"amenityFeature":[{"@type":"LocationFeatureSpecification","name":"Centralised AC","value":true},{"@type":"LocationFeatureSpecification","name":"Valet Parking","value":true},{"@type":"LocationFeatureSpecification","name":"Changing Rooms","value":true},{"@type":"LocationFeatureSpecification","name":"Stage & Projector","value":true},{"@type":"LocationFeatureSpecification","name":"Havan Allowed","value":true},{"@type":"LocationFeatureSpecification","name":"Power Backup","value":true},{"@type":"LocationFeatureSpecification","name":"In-House Catering","value":true},{"@type":"LocationFeatureSpecification","name":"In-House Décor","value":true}],"image":"https://assets.zyrosite.com/cdn-cgi/image/format=auto,w=2000/MBlLcEqY2yw3y2EF/115a6487-ovJFGLVkQmHn96bH.JPG","hasMap":"https://maps.google.com/?q=Bika+Banquets+Golaghata+Dakshindari+Kolkata"}15:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{